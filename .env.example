# =============================================================================
# Lens — env template for non-development deployments
# =============================================================================
# Copy to .env.production or .env.runtime. Real values come from Infisical
# (agent-lens machine identity) on the production VM.
# =============================================================================

# ---- App ----
ENVIRONMENT=production

# ---- Postgres (shared loyd-pg) ----
DATABASE_URL=postgresql+asyncpg://lens_app:CHANGEME@loyd-pg.netsmart.tech:5432/loyd

# ---- Backend ----
BACKEND_PORT=8100
CORS_ORIGINS=https://lens.netsmart.tech

# ---- Frontend ----
FRONTEND_PORT=3100
NEXT_PUBLIC_API_URL=https://lens.netsmart.tech

# ---- Auth (Authentik OIDC — prod app) ----
OIDC_CLIENT_ID=lens-prod
OIDC_CLIENT_SECRET=CHANGEME
OIDC_REDIRECT_URI=https://lens.netsmart.tech/api/auth/callback
OIDC_AUTHORIZE_URL=https://auth.netsmart.tech/application/o/authorize/
OIDC_TOKEN_URL=https://auth.netsmart.tech/application/o/token/
OIDC_USERINFO_URL=https://auth.netsmart.tech/application/o/userinfo/
OIDC_FRONTEND_URL=https://lens.netsmart.tech/

LENS_DEV_AUTH=0

# ---- Secrets proxy (mTLS — identity: lens) ----
SECRETS_PROXY_URL=https://secrets-proxy.netsmart.tech
SECRETS_PROXY_CLIENT_CERT=/etc/lens/secrets-proxy.crt
SECRETS_PROXY_CLIENT_KEY=/etc/lens/secrets-proxy.key
SECRETS_PROXY_CA_CERT=/etc/lens/secrets-proxy-ca.crt

# ---- Per-tenant Jira config (URL only — auth uses {secret:<slug>-jira-api-token} via proxy) ----
# JIRA_TOPBUILD_URL=https://topbuild.atlassian.net
# JIRA_NETSMART_URL=https://netsmart.atlassian.net

# ---- Anthropic (used for report narration; fetched via secrets proxy) ----
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- GHCR (for pull-deploy.sh) ----
GHCR_READ_TOKEN=CHANGEME
